</div>

</div>

<table>

<tr>
{% for c in cols %}
<th>{{c}}</th>
{% endfor %}
</tr>

{% for r in rows %}

<tr class="
{% if r.result == 'TARGET HIT' %}
flash-green
{% elif r.result == 'SL HIT' %}
flash-red
{% elif r.result == 'ACTIVE' %}
flash-blue
{% endif %}
">

{% for c in cols %}

<td class="{% if c=='current_pnl' or c=='max_profit' %}highlight-col{% endif %}">
{{r[c]}}
</td>

{% endfor %}

</tr>

{% endfor %}

</table>

</body>
</html>
"""

# ============================================================
# FLASK
# ============================================================

app = Flask(__name__)

@app.route("/")

def index():

    cols = [
        "buy_time",
        "target_hit_time",
        "stock_name",
        "LTP",
        "change_percent",
        "gainer_loser",
        "option_name",
        "current_price",
        "buy_price",
        "qty",
        "investment",
        "sl_price",
        "max_loss",
        "target_price",
        "net_profit",
        "current_pnl",
        "max_profit",
        "todays_high",
        "percentage",
        "result"
    ]

    (
        data,
        total,
        t_inv,
        t_profit,
        t_max,
        g,
        l,
        s,
        sentiment,
        total_trades,
        target_hit,
        sl_hit,
        active,
        win_rate
    ) = generate_rows()

    return render_template_string(
        HTML,
        rows=data,
        cols=cols,
        total=round(total, 2),
        t_inv=round(t_inv, 2),
        t_profit=round(t_profit, 2),
        t_max=round(t_max, 2),
        g=g,
        l=l,
        s=s,
        sentiment=sentiment,
        total_trades=total_trades,
        target_hit=target_hit,
        sl_hit=sl_hit,
        active=active,
        win_rate=round(win_rate, 2)
    )

if __name__ == "__main__":

    app.run(
        host="0.0.0.0",
        port=5003
    )

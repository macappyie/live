}

.highlight-col{
background:#002a34;
color:#00ffff;
font-weight:bold;
}

th{
background:#ffffff;
color:#000000;
font-weight:bold;
}

table{
width:100%;
border-collapse:collapse;
}

td,th{
border:1px solid #333;
padding:5px;
}

</style>

</head>

<body>


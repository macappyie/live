}

.highlight-col{background-color:#002a34;color:#00ffff;font-weight:bold;}

th{background:#001f2b;color:#00ffff;border-bottom:2px solid #00ffff;}

@keyframes blinkGreen{0%{background:#006400;}50%{background:#00ff00;}100%{background:#006400;}}

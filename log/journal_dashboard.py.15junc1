from flask import Flask, render_template_string
from kiteconnect import KiteConnect
import pandas as pd
import datetime as dt
import pytz

# ---------- CONFIG ----------
API_KEY = "awh2j04pcd83zfvq"
kite = KiteConnect(api_key=API_KEY)

with open("access_token.txt") as f:
    kite.set_access_token(f.read().strip())

IST = pytz.timezone("Asia/Kolkata")

with open("watchlist.txt") as f:
    WATCHLIST = [f"NSE:{x.strip()}" for x in f if x.strip()]

INS = pd.read_csv("instruments.csv", low_memory=False)
INS["expiry"] = pd.to_datetime(INS["expiry"], errors="coerce")


# ✅ FREEZE STORAGE
FROZEN_ROWS = {}

# ============================================================
# ✅ 9:30 SIGNAL LOGIC (FINAL)
# ============================================================

def get_930_signal(symbol, side):
    try:
        token = kite.ltp(symbol)[symbol]["instrument_token"]

        now = dt.datetime.now(IST)
        from_dt = IST.localize(dt.datetime.combine(now.date(), dt.time(9, 15)))
        to_dt   = IST.localize(dt.datetime.combine(now.date(), dt.time(9, 35)))

        df = pd.DataFrame(kite.historical_data(token, from_dt, to_dt, "5minute"))
        if df.empty:
            return None

        df["date"] = pd.to_datetime(df["date"])
        df.set_index("date", inplace=True)

        # ✅ Opening 3 candles
        pre = df[(df.index.hour == 9) & (df.index.minute.isin([15, 20, 25]))]
        if pre.empty:
            return None

        # ✅ 9:30 candle
        c930 = df[(df.index.hour == 9) & (df.index.minute == 30)]
        if c930.empty:
            return None

        # ===================== GAINER =====================
        if side == "GAINER":
            range_high = pre["high"].max()
            c930_high = c930["high"].iloc[0]

            if c930_high < range_high:
                return round(c930_high + 1, 2)

        # ===================== LOSER =====================
        elif side == "LOSER":
            range_high = pre["high"].max()
            c930_high = c930["high"].iloc[0]

            if c930_high < range_high:
                return round(c930_high + 1, 2)

        return None

    except:
        return None


# ============================================================
# AFTER 9:30 HIGH
# ============================================================

def get_after_930_high(symbol):
    try:
        token = kite.ltp(symbol)[symbol]["instrument_token"]
        now = dt.datetime.now(IST)

        from_dt = IST.localize(dt.datetime.combine(now.date(), dt.time(9,15)))

        df = pd.DataFrame(kite.historical_data(token, from_dt, now, "5minute"))
        if df.empty:
            return None

        df["date"] = pd.to_datetime(df["date"])
        df.set_index("date", inplace=True)

        c = df[(df.index.hour == 9) & (df.index.minute == 30)]
        if c.empty:
            return None

        after = df[df.index > c.index[0]]

        return round(after["high"].max(), 2) if not after.empty else None

    except:
        return None
# ============================================================
# TARGET HIT CANDLE TIME (5 MIN)
# ============================================================

def get_target_hit_time(symbol, target):
    try:
        token = kite.ltp(symbol)[symbol]["instrument_token"]
        now = dt.datetime.now(IST)

        from_dt = IST.localize(dt.datetime.combine(now.date(), dt.time(9,15)))

        df = pd.DataFrame(kite.historical_data(token, from_dt, now, "5minute"))
        if df.empty:
            return "-"

        df["date"] = pd.to_datetime(df["date"])

        for _, row in df.iterrows():
            if row["high"] >= target:
                return row["date"].strftime("%H:%M")

        return "-"

    except:
        return "-"


# ========================================
# ============================================================
# BUY HIT TIME (5 MIN CANDLE)
# ============================================================

def get_buy_hit_time(symbol, buy_price):
    try:
        token = kite.ltp(symbol)[symbol]["instrument_token"]
        now = dt.datetime.now(IST)

        from_dt = IST.localize(dt.datetime.combine(now.date(), dt.time(9,15)))

        df = pd.DataFrame(kite.historical_data(token, from_dt, now, "5minute"))
        if df.empty:
            return "-"

        df["date"] = pd.to_datetime(df["date"])

        # ✅ 9:30 candle find करो
        c930 = df[(df["date"].dt.hour == 9) & (df["date"].dt.minute == 30)]
        if c930.empty:
            return "-"

        c930_time = c930.iloc[0]["date"]

        # ✅ सिर्फ 9:30 के बाद वाली candle
        after = df[df["date"] > c930_time]

        # ✅ breakout check
        for _, row in after.iterrows():
            if row["high"] >= buy_price:
                return row["date"].strftime("%H:%M")

        return "-"

    except:
        return "-"
# ==================================================

# ============================================================
# OPTION SELECTION
# ============================================================

def get_option(stock, opt_type, ref_price):
    try:
        today = dt.date.today()

        df = INS[
            (INS["name"] == stock) &
            (INS["segment"] == "NFO-OPT") &
            (INS["instrument_type"] == opt_type) &
            (INS["expiry"].dt.date >= today)
        ]

        if df.empty:
            return None, 0

        df = df.sort_values("expiry")
        df["diff"] = abs(df["strike"] - ref_price)

        atm = df.sort_values("diff").iloc[0]

        return f"NFO:{atm['tradingsymbol']}", int(atm["lot_size"])

    except:
        return None, 0


# ============================================================
# MAIN ENGINE
# ============================================================

def generate_rows():
    global FROZEN_ROWS

    rows = []
    quotes = kite.quote(WATCHLIST)

    temp = []
    gainer = loser = sideways = 0

    # ✅ COUNTERS
    total = t_inv = t_profit = t_max = 0
    target_hit = sl_hit = active = 0
    no_trade_count = 0

    # ================================
    # STOCK LOOP
    # ================================
    for s in WATCHLIST:
        try:
            q = quotes[s]
            stock = s.replace("NSE:", "")

            ltp = q["last_price"]
            prev = q["ohlc"]["close"]

            change = ((ltp - prev) / prev) * 100

            if change > 0:
                gainer += 1
                side = "GAINER"
            elif change < 0:
                loser += 1
                side = "LOSER"
            else:
                sideways += 1
                side = "SIDE"

            temp.append({
                "stock": stock,
                "ltp": ltp,
                "change": round(change, 2),
                "side": side
            })
        except:
            pass

    # ✅ TOP FILTER
    gainers = sorted([x for x in temp if x["change"] > 0],
                     key=lambda x: x["change"], reverse=True)[:25]

    losers = sorted([x for x in temp if x["change"] < 0],
                    key=lambda x: abs(x["change"]), reverse=True)[:25]

    final = gainers + losers

    sentiment = "BULLISH" if gainer > loser else "BEARISH" if loser > gainer else "SIDEWAYS"

    # ================================
    # MAIN LOOP
    # ================================
    for r in final:
        try:
            stock = r["stock"]

            # ✅ ✅ SMART FREEZE (IMPORTANT)
            if stock in FROZEN_ROWS:
                frozen = FROZEN_ROWS[stock]

                option = "NFO:" + frozen["option_name"]

                try:
                    current = kite.ltp(option)[option]["last_price"]
                except:
                    current = frozen["current_price"]

                high = get_after_930_high(option) or frozen["todays_high"]

                buy = frozen["buy_price"]
                qty = frozen["qty"]

                current_pnl = (current - buy) * qty
                max_profit = (high - buy) * qty
                percent_move = round(((high - buy) / buy) * 100, 2) if buy > 0 else 0

                frozen["current_price"] = round(current, 2)
                frozen["current_pnl"] = round(current_pnl, 2)
                frozen["max_profit"] = round(max_profit, 2)
                frozen["todays_high"] = high
                frozen["percentage"] = percent_move

                rows.append(frozen)

                # ✅ COUNTERS
                if frozen["result"] == "TARGET HIT":
                    target_hit += 1
                    t_inv += frozen["investment"]
                    t_profit += frozen["net_profit"]
                    t_max += frozen["max_profit"]

                elif frozen["result"] == "SL HIT":
                    sl_hit += 1

                elif frozen["result"] == "ACTIVE":
                    active += 1

                continue

            side = r["side"]

            # ✅ STOCK 9:30 CHECK
            stock_930 = get_930_signal(f"NSE:{stock}", side)

            if not stock_930:
                no_trade_count += 1
                rows.append({
                    "stock_name": stock,
                    "LTP": round(r["ltp"], 2),
                    "change_percent": r["change"],
                    "gainer_loser": side,
                    "result": "NO TRADE"
                })
                continue

            # ✅ OPTION SELECT
            opt_type = "CE" if side == "GAINER" else "PE"
            option, qty = get_option(stock, opt_type, stock_930)

            if not option:
                continue

            current = kite.ltp(option)[option]["last_price"]
            buy = get_930_signal(option, side)

            if not buy:
                continue

            high = get_after_930_high(option) or 0

            # ✅ NOT TRIGGER
            if high < buy:
                rows.append({
                    "stock_name": stock,
                    "option_name": option.replace("NFO:", ""),
                    "current_price": round(current, 2),
                    "buy_price": buy,
                    "result": "PENDING"
                })
                continue

            # ✅ TRADE CALC
            sl = round(buy * 0.85, 2)
            target = round(buy * 1.3, 2)

            investment = buy * qty
            total += investment

            net_profit = (target - buy) * qty
            max_profit = (high - buy) * qty
            current_pnl = (current - buy) * qty

            percent_move = round(((high - buy) / buy) * 100, 2)

            # ✅ RESULT
            if high >= target:
                result = "TARGET HIT"
                target_hit += 1
                t_inv += investment
                t_profit += net_profit
                t_max += max_profit

            elif current <= sl:
                result = "SL HIT"
                sl_hit += 1
            else:
                result = "ACTIVE"
                active += 1

            row = {
                "buy_time": get_buy_hit_time(option, buy),
                "stock_name": stock,
                "LTP": round(r["ltp"], 2),
                "change_percent": r["change"],
                "gainer_loser": side,
                "option_name": option.replace("NFO:", ""),
                "current_price": round(current, 2),
                "buy_price": buy,
                "qty": qty,
                "investment": round(investment, 2),
                "sl_price": sl,
                "target_price": target,
                "net_profit": round(net_profit, 2),
                "current_pnl": round(current_pnl, 2),
                "max_profit": round(max_profit, 2),
                "todays_high": high,
                "percentage": percent_move,
                "result": result
            }

            rows.append(row)

            # ✅ FREEZE STORE
            if result in ["ACTIVE", "TARGET HIT", "SL HIT"]:
                FROZEN_ROWS[stock] = row

        except:
            pass

    total_trades = target_hit + sl_hit + active
    win_rate = (target_hit / total_trades * 100) if total_trades > 0 else 0

    return rows, total, t_inv, t_profit, t_max, gainer, loser, sideways, sentiment, total_trades, target_hit, sl_hit, active, win_rate, 0, 0, no_trade_count


# ============================================================
# UI
# ============================================================

# ---------- UI (UNCHANGED) ----------
HTML = """
<html>
<head>
<meta http-equiv="refresh" content="3">
<style>
body{background:#000;color:#fff;font-family:Arial;}

.center{text-align:center;margin:20px;}


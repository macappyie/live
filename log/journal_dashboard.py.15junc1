<h3>GAINERS: {{g}} | LOSERS: {{l}} | SIDEWAYS: {{s}}</h3>
<h2 style="color:{% if sentiment=='BULLISH'%}lime{% elif sentiment=='BEARISH'%}red{% else %}yellow{% endif %}">
MARKET SENTIMENT: {{sentiment}}
</h2>
</div>

<h1 style="color:#00ffcc;">TOTAL INVESTED: ₹{{total}}</h1>
<h2 style="color:yellow;">
NET PROFIT: ₹{{t_profit}} | INVESTED: ₹{{t_inv}} 
</h2>
<h2 style="color:magenta;">MAX PROFIT: ₹{{t_max}}</h2>


<div style="position:absolute;top:140px;right:30px;text-align:right;">

<div style="font-size:28px;font-weight:bold;">
TOTAL TRADES: {{total_trades}}
</div>

<div style="font-size:26px;font-weight:bold;color:#00ff00;">
TARGET HIT: {{target_hit}}
</div>

<div style="font-size:26px;font-weight:bold;color:#ff0000;">
